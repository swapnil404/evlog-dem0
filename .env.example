# Root .env for Alchemy (optional, used for deployment)
# Copy values from apps/web/.env and apps/server/.env

# Required for Alchemy secret encryption
ALCHEMY_PASSWORD=your-alchemy-password-here

VITE_SERVER_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3001
BETTER_AUTH_SECRET=your-secret-key-here
BETTER_AUTH_URL=http://localhost:3000
POLAR_ACCESS_TOKEN=your-polar-access-token
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
POLAR_SUCCESS_URL=http://localhost:3001/dashboard
